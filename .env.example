# JTV bot app credentials (from https://joystick.tv developer settings)
JOYSTICK_BOT_ID=
JOYSTICK_BOT_SECRET=

# Bot account's own JTV username — used to filter out the bot's own chat messages
BOT_USERNAME=

# Public base URL of THIS service (scheme + host only, no trailing slash, no path).
# Example: https://turbotack.rustyblu.com
PUBLIC_BASE_URL=https://turbotack.rustyblu.com

# Path prefix the reverse proxy forwards to us. Required when multiple bots
# share a host. No trailing slash. Leave empty for standalone deployment.
# Example: /nobot  →  live redirect is https://turbotack.rustyblu.com/nobot/auth/callback
ROOT_PATH=/nobot

# Long random string used to sign internal state (oauth state param, etc). Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
APP_SECRET=

# Optional: override the no-as-a-service endpoint if the default is down
# NAAS_URL=https://naas.isalman.dev/no

# Optional: override DB path
# DB_PATH=nobot.db

# Optional: override bind host/port
# HOST=0.0.0.0
# PORT=8000
